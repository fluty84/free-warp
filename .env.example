# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual keys.

# URL of your LiteLLM-compatible gateway.
# Default when unset: http://localhost:4000
WARP_LLM_BYOK_BASE_URL=https://your-litellm.example.com

# Your LiteLLM virtual key (sk-...).
# Paste this same value in Settings → AI → OpenAI API Key inside the app.
LITELLM_API_KEY=sk-...
